{
  "mcpServers": {
    "sonic-voip-analyzer": {
      "command": "python3",
      "args": ["/absolute/path/to/sonic/mcp_server.py"],
      "env": {
        "SONIC_LLM_PROVIDER": "ollama"
      }
    }
  }
}

// Optional: Use cloud provider
